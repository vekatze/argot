import {
  core.box {axiom-T},
  core.list {append, span},
  core.sync.cell {borrow, modify},
  this.argot-kit {_Argot-Kit, argot-kit},
  this.error {Key-Missing, Unexpected-End-Of-Input, Value-Missing, error},
}

define _break-at-key(xs: list(string), key: &string) -> pair(list(string), list(string)) {
  span(xs, (x) => {
    ne-string(x, key)
  })
}

define get-num-of-items(k: &argot-kit) -> int {
  tie _Argot-Kit{input-ref} = k;
  borrow(input-ref, (xs) => {
    lift {core.list.length(xs)}
  })
}

define export-state(k: &argot-kit) -> list(string) {
  tie _Argot-Kit{input-ref} = k;
  core.sync.cell.clone(input-ref)
}

define import-state(k: &argot-kit, xs: list(string)) -> unit {
  tie _Argot-Kit{input-ref} = k;
  core.sync.cell.mutate(input-ref, (_) => {
    lift {xs}
  })
}

define pop-key(k: &argot-kit, key: &string) -> bool {
  tie _Argot-Kit{input-ref} = k;
  core.sync.cell.modify(input-ref, (input) => {
    let input = axiom-T(input);
    let Pair(ys, zs) = _break-at-key(input, key);
    match zs {
    | Nil =>
      Pair(lift {ys}, False)
    | Cons(_, rest) =>
      Pair(lift {append(ys, rest)}, True)
    }
  })
}

define pop-key-value(k: &argot-kit, key: &string) -> either(error, string) {
  tie _Argot-Kit{input-ref} = k;
  modify(input-ref, (input) => {
    let input = axiom-T(input);
    let Pair(ys, zs) = _break-at-key(input, key);
    match zs {
    | Cons(_, Cons(z2, rest)) =>
      Pair(lift {append(ys, rest)}, Right(z2))
    | Cons(z, Nil) =>
      Pair(lift {append(ys, Cons(z, Nil))}, Left(Value-Missing(*key)))
    | zs =>
      Pair(lift {append(ys, zs)}, Left(Key-Missing(*key)))
    }
  })
}

define pop-head(k: &argot-kit) -> either(error, string) {
  tie _Argot-Kit{input-ref} = k;
  modify(input-ref, (input) => {
    let input = axiom-T(input);
    match input {
    | Nil =>
      Pair(lift {Nil}, Left(Unexpected-End-Of-Input))
    | Cons(x, xs) =>
      Pair(lift {xs}, Right(x))
    }
  })
}
