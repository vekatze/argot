import {
  core.string {format},
}

data error {
| Key-Missing(key: string)
| Value-Missing(key: string)
| Parse-Failure(key: string, value: string)
| Remaining-Arguments(rest: list(string))
| Unexpected-End-Of-Input
}

define report(e: error) -> string {
  match e {
  | Key-Missing(key) =>
    format("Missing key: {}", List[key])
  | Value-Missing(key) =>
    format("Missing value for key: {}", List[key])
  | Parse-Failure(key, value) =>
    format("Could not parse `{}` at `{}`", List[value, key])
  | Remaining-Arguments(rest) =>
    format("Extra arguments: {}", List[
      core.string.intercalate(rest, *" "),
    ])
  | Unexpected-End-Of-Input =>
    *"Unexpected end of input"
  }
}
