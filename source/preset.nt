import {
  core.float.parse {parse-float},
  core.int.parse {parse-int},
  this.argot {argot},
  this.error {Parse-Failure},
  this.state {pop-head, pop-key, pop-key-value},
}

inline flag(key: &string) -> argot(bool) {
  (k) => {
    Right(pop-key(k, key))
  }
}

inline int-required(key: &string) -> argot(int) {
  (k) => {
    try value = pop-key-value(k, key);
    let parse-result on value = parse-int(value);
    match parse-result {
    | Left(_) =>
      Left(Parse-Failure(*key, value))
    | Right(v) =>
      Right(v)
    }
  }
}

inline float-required(key: &string) -> argot(float) {
  (k) => {
    try value = pop-key-value(k, key);
    let parse-result on value = parse-float(value);
    match parse-result {
    | Left(_) =>
      Left(Parse-Failure(*key, value))
    | Right(v) =>
      Right(v)
    }
  }
}

inline string-required(key: &string) -> argot(string) {
  (k) => {
    try value = pop-key-value(k, key);
    Right(value)
  }
}

constant string-argument: argot(string) {
  (k) => {
    try value = pop-head(k);
    Right(value)
  }
}
